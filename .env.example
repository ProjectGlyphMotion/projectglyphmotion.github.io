# Core bot/auth secrets
# IMPORTANT: Telegram support is OPTIONAL and DISABLED by default due to regional bans (e.g., India)
# The web server (port 5000) works fully in India
# To enable Telegram bot:
#   1. Set TELEGRAM_BOT_TOKEN with your bot token
#   2. Set ENABLE_TELEGRAM=true
#   3. Run: pip install python-telegram-bot
# If you don't set ENABLE_TELEGRAM=true, the script will run in web-server-only mode (fully functional)
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
ENABLE_TELEGRAM=false
JWT_SECRET_KEY=replace_with_strong_random_secret

# GitHub integration
GITHUB_ACCESS_TOKEN=replace_with_github_pat
GITHUB_USERNAME=ProjectGlyphMotion
GITHUB_REPO_NAME=ProjectGlyphMotion.github.io
GITHUB_BRANCH=main

# Google Drive integration
GOOGLE_DRIVE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_DRIVE_TOKEN_FILE=token.json
GOOGLE_DRIVE_OUTPUT_FOLDER_NAME=ObjectTrackerMaster/output

# web_server_public.py automation
GITHUB_PAT=replace_with_github_pat
CLOUDFLARE_TUNNEL_NAME=project-glyph-motion-org-tunnel
CLOUDFLARE_CUSTOM_DOMAIN=projectglyphmotion.studio
